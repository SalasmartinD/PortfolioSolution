@page "/projects"
@using Portfolio.Shared.Models 
@using Portfolio.Client.Components
@using Portfolio.Client.Services
@inject ProjectService ProjectService 

<div class="container py-5">
    <h3 class="display-5 fw-bold mb-4 border-bottom pb-2 text-primary">
        <i class="fas fa-code me-2"></i> Mis Proyectos Destacados
    </h3>
    <p class="lead text-muted">
        Estos proyectos demuestran mi experiencia en el desarrollo de aplicaciones robustas implementando buenas prácticas.
    </p>
    
    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center my-5 py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="lead text-muted mt-3">Cargando proyectos desde Supabase...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger my-5 p-4 border-0 shadow-sm" role="alert">
            <h4 class="alert-heading fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Error al cargar proyectos</h4>
            <p class="mb-3">Hubo un problema al intentar conectar con la base de datos de Supabase. Por favor, verifica la configuración de conexión o reintenta.</p>
            <hr>
            <p class="mb-3 text-monospace small text-dark">Detalle técnico: @errorMessage</p>
            <button class="btn btn-danger btn-sm px-4" @onclick="LoadProjectsAsync">
                <i class="fas fa-sync me-1"></i> Intentar de nuevo
            </button>
        </div>
    }
    else if (projects == null || !projects.Any())
    {
        <div class="text-center my-5 py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <p class="lead text-muted">No se encontraron proyectos registrados en este momento.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4 mt-3"> 
            @foreach (var project in projects)
            {
                <ProjectCard Project="@project" />
            }
        </div>
    }
</div>

@code {
    private List<Project>? projects;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    private async Task LoadProjectsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            projects = await ProjectService.GetProjectsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Error al obtener proyectos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}