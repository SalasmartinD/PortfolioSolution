@using Portfolio.Shared.Models

<div class="col">
    <div class="glass-card border-0 h-100">
        <div class="card-body d-flex flex-column">
            
            <h5 class="card-title mb-3">
                <i class="fas fa-folder me-2 text-primary"></i> @Project.Title
            </h5>
            
            <p class="card-text flex-grow-1 overflow-auto project-description mb-4">@Project.ShortDescription</p>
            
            <h6 class="text-muted small fw-bold mb-2 text-uppercase" style="letter-spacing: 0.05em;">Tecnologías Clave</h6>
            <div class="mt-auto project-technologies d-flex flex-wrap gap-2 mb-4"> 
                @if (!string.IsNullOrEmpty(Project.Technologies))
                {
                    @foreach (var tech in Project.Technologies.Split(',', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="tech-badge text-break">@tech.Trim()</span> 
                    }
                }
            </div>
        </div>
        
        <div class="card-footer bg-transparent border-0 d-grid gap-2 px-4 pb-4 pt-0">
            @if (!string.IsNullOrWhiteSpace(Project.LiveDemoUrl))
            {
                <a href="@Project.LiveDemoUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-external-link-alt me-2"></i> Demo en Vivo
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(Project.GitHubUrl))
            {
                <a href="@Project.GitHubUrl" target="_blank" class="btn btn-sm btn-gradient text-white">
                    <i class="fab fa-github me-2"></i> Código Fuente
                </a>
            }
            else
            {
                <button class="btn btn-sm btn-outline-secondary text-muted border-secondary" disabled>
                    <i class="fas fa-lock me-2"></i> Repositorio Privado
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Project Project { get; set; } = new Project();
}